{
  "name": "ai-factory-kaizen-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["ai-factory-kaizen"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "dependsOn": ["ai-factory-kaizen:build", "ai-factory-kaizen:serve"],
      "options": {
        "jestConfig": "packages/ai-factory-kaizen-e2e/jest.config.cts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
